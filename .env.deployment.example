# =============================================================================
# AI Community Platform — Deployment Configuration
# =============================================================================
# This file contains deployment-specific environment variables that can be
# customized for different deployment modes (Docker Compose, Kubernetes, etc.)
#
# Copy this file to .env.deployment and customize for your environment:
#   cp .env.deployment.example .env.deployment
#
# These variables provide defaults that work for Docker Compose but can be
# overridden for other deployment modes like Kubernetes.
# =============================================================================

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# PostgreSQL connection details
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=ai_community_platform

# Constructed DATABASE_URL (can be overridden entirely if needed)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?serverVersion=16&charset=utf8
POSTGRES_PROVISIONER_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/postgres?serverVersion=16&charset=utf8

# ---------------------------------------------------------------------------
# Redis Configuration
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ---------------------------------------------------------------------------
# OpenSearch Configuration
# ---------------------------------------------------------------------------
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://${OPENSEARCH_HOST}:${OPENSEARCH_PORT}

# ---------------------------------------------------------------------------
# RabbitMQ Configuration
# ---------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=app
RABBITMQ_PASSWORD=app
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}

# ---------------------------------------------------------------------------
# LiteLLM Configuration
# ---------------------------------------------------------------------------
LITELLM_HOST=litellm
LITELLM_PORT=4000
LITELLM_BASE_URL=http://${LITELLM_HOST}:${LITELLM_PORT}
LITELLM_API_KEY=dev-key

# ---------------------------------------------------------------------------
# Langfuse Configuration
# ---------------------------------------------------------------------------
LANGFUSE_HOST=langfuse-web
LANGFUSE_PORT=3000
LANGFUSE_BASE_URL=http://${LANGFUSE_HOST}:${LANGFUSE_PORT}
LANGFUSE_PUBLIC_KEY=lf_pk_local_dev
LANGFUSE_SECRET_KEY=lf_sk_local_dev
LANGFUSE_ENV=local
LANGFUSE_ENABLED=true

# ---------------------------------------------------------------------------
# Core Platform Configuration
# ---------------------------------------------------------------------------
CORE_PLATFORM_HOST=core
CORE_PLATFORM_PORT=80
CORE_PLATFORM_URL=http://${CORE_PLATFORM_HOST}

# ---------------------------------------------------------------------------
# Public URLs (for admin interfaces and external access)
# ---------------------------------------------------------------------------
# Base domain for public access (localhost for development, your domain for production)
PUBLIC_DOMAIN=localhost

# Admin interface URLs
ADMIN_OPENCLAW_URL=http://openclaw.${PUBLIC_DOMAIN}/
ADMIN_LANGFUSE_URL=http://langfuse.${PUBLIC_DOMAIN}/
ADMIN_TRAEFIK_URL=http://traefik.${PUBLIC_DOMAIN}/dashboard/
ADMIN_LITELLM_URL=http://litellm.${PUBLIC_DOMAIN}/ui/

# ---------------------------------------------------------------------------
# Edge Authentication Configuration
# ---------------------------------------------------------------------------
EDGE_AUTH_JWT_SECRET=dev-edge-auth-secret-change-me
EDGE_AUTH_COOKIE_NAME=ACP_EDGE_TOKEN
EDGE_AUTH_TOKEN_TTL=43200
EDGE_AUTH_LOGIN_BASE_URL=http://${PUBLIC_DOMAIN}
EDGE_AUTH_COOKIE_DOMAIN=${PUBLIC_DOMAIN}

# ---------------------------------------------------------------------------
# Agent-Specific Database Configuration
# ---------------------------------------------------------------------------
# Knowledge Agent
KNOWLEDGE_AGENT_DB_USER=knowledge_agent
KNOWLEDGE_AGENT_DB_PASSWORD=knowledge_agent
KNOWLEDGE_AGENT_DB_NAME=knowledge_agent
KNOWLEDGE_AGENT_DATABASE_URL=postgresql://${KNOWLEDGE_AGENT_DB_USER}:${KNOWLEDGE_AGENT_DB_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${KNOWLEDGE_AGENT_DB_NAME}?serverVersion=16&charset=utf8

# News Maker Agent
NEWS_MAKER_AGENT_DB_USER=news_maker_agent
NEWS_MAKER_AGENT_DB_PASSWORD=news_maker_agent
NEWS_MAKER_AGENT_DB_NAME=news_maker_agent
NEWS_MAKER_AGENT_DATABASE_URL=postgresql://${NEWS_MAKER_AGENT_DB_USER}:${NEWS_MAKER_AGENT_DB_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${NEWS_MAKER_AGENT_DB_NAME}

# ---------------------------------------------------------------------------
# Internal Security
# ---------------------------------------------------------------------------
APP_INTERNAL_TOKEN=dev-internal-token