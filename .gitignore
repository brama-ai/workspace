.DS_Store
.idea/

# Claude Code — only local settings are personal
.claude/settings.local.json
.claude/pipeline/

# Pipeline artifacts (agent run results)
artifacts/

# Cursor — track skills, ignore the rest
.cursor/*

# OpenCode — track skills/agents/commands, ignore runtime
.opencode/node_modules/
.opencode/bun.lock
.opencode/.DS_Store
.opencode/pipeline/
.opencode/oh-my-opencode.jsonc
.opencode/opencode.json
.opencode/package.json
.opencode/.gitignore

# Agent — track workflows, ignore the rest
.agent/*
!.agent/workflows/

# VS Code — track extensions, ignore settings (contains credentials)
.vscode/*
!.vscode/extensions.json

# Secrets and local state
.env.local
.env.deployment
.env.*.local
.devcontainer/.ssh-env
.local/
docker/openclaw/.env
docker/openclaw/main/.env
docker/openclaw/support/.env
compose.override.yaml
compose.override.yml
brama-agents/

# External repositories
brama-core/
brama-website/

# Foundry runtime state
tasks/
agentic-development/runtime/*
!agentic-development/runtime/.gitkeep

# E2E test directories
tasks-e2e-test/
agentic-development/tests/e2e-agents/tasks-e2e-isolated/
agentic-development/tests/e2e-agents/test-results/

# Doctor root cause reports (auto-generated)
agentic-development/doctor/root-cause-*.md
agentic-development/monitor/node_modules/

# Foundry persistent model blacklist (runtime state, not source)
.foundry-blacklist.json
.claude/
.foundry-runner.lock
