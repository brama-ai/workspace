# =============================================================================
# DEPRECATED — use templates/agent/compose.fragment.yaml instead
# =============================================================================
#
# All scaffold templates have moved to the templates/ directory.
# See: templates/agent/compose.fragment.yaml
#
# Usage:
#   cp templates/agent/compose.fragment.yaml compose.fragments/<agent-name>.yaml
#   make external-agent-up name=<agent-name>
#
# =============================================================================

services:
  example-agent:
    # Build from the checked-out agent repository
    build:
      context: ./agents/example-agent
      dockerfile: Dockerfile
    labels:
      # Required: marks this service for platform discovery
      - ai.platform.agent=true
      # Required: Traefik routing (adjust entrypoint name and port as needed)
      - traefik.enable=true
      - traefik.http.routers.example-agent.rule=PathPrefix(`/`)
      - traefik.http.routers.example-agent.entrypoints=example
      - traefik.http.routers.example-agent.middlewares=edge-auth@docker
      - traefik.http.services.example-agent.loadbalancer.server.port=80
    environment:
      # Platform integration — always required
      PLATFORM_CORE_URL: http://core
      APP_INTERNAL_TOKEN: dev-internal-token
      # Agent-specific env — adjust as needed
      # DATABASE_URL: postgresql://example_agent:example_agent@postgres:5432/example_agent
      # REDIS_URL: redis://redis:6379/4
    env_file:
      # Optional: agent-specific secrets (gitignored on the platform side)
      - path: ./agents/example-agent/.env.local
        required: false
    healthcheck:
      # Required: platform polls /health every 60s
      test: ["CMD-SHELL", "curl -sf http://localhost/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    depends_on:
      - postgres
    networks:
      - dev-edge

# Note: do NOT redefine the dev-edge network here.
# It is already declared in compose.yaml and shared across all fragments.
