#!/usr/bin/env bash
#
# foundry - Pipeline Orchestrator (TypeScript CLI)
#
# Single entrypoint for all foundry commands.
# All routing (TS commands + legacy bash) is handled in foundry.ts.
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${REPO_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

export REPO_ROOT
export PIPELINE_TASKS_ROOT="${PIPELINE_TASKS_ROOT:-$REPO_ROOT/tasks}"

# Prefer compiled JS (faster, no tsx/esbuild dependency).
# Fall back to tsx for development when dist is stale.
DIST="$SCRIPT_DIR/monitor/dist/cli/foundry.js"
if [[ -f "$DIST" ]]; then
  exec node "$DIST" "$@"
else
  exec npx tsx "$SCRIPT_DIR/monitor/src/cli/foundry.ts" "$@"
fi
