# E2E test URLs for running inside devcontainer
# Devcontainer shares docker network but cannot use localhost ports.
# Use docker DNS names (container names) instead.

# Core
BASE_URL=http://brama-core-e2e-1:80
CORE_DB_NAME=brama_test

# Agents
HELLO_URL=http://brama-hello-agent-e2e-1:80
HELLO_AGENT_URL=http://brama-hello-agent-e2e-1:80
KNOWLEDGE_URL=http://brama-knowledge-agent-e2e-1:80
KNOWLEDGE_AGENT_URL=http://brama-knowledge-agent-e2e-1:80
NEWS_URL=http://brama-news-maker-agent-e2e-1:8000
NEWS_MAKER_AGENT_URL=http://brama-news-maker-agent-e2e-1:8000
DEV_REPORTER_AGENT_URL=http://brama-dev-reporter-agent-e2e-1:80
DEV_REPORTER_URL=http://brama-dev-reporter-agent-e2e-1:80

# OpenClaw
OPENCLAW_URL=http://brama-openclaw-gateway-e2e-1:28789

# Infrastructure (direct ports)
TRAEFIK_API=http://brama-traefik-1:8080
RABBITMQ_URL=http://brama-rabbitmq-1:15672
OPENSEARCH_URL=http://brama-opensearch-1:9200

# Traefik-routed services (use traefik as reverse proxy)
TRAEFIK_DASHBOARD_URL=http://brama-traefik-1:8080
LITELLM_URL=http://brama-litellm-1:4000
LANGFUSE_URL=http://brama-langfuse-server-1:3000
OPENSEARCH_DASHBOARDS_URL=http://brama-opensearch-dashboards-1:5601
