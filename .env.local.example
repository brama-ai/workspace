# =============================================================================
# AI Community Platform — Local Development Secrets
# =============================================================================
# Copy this file to .env.local and fill in your values:
#
#   cp .env.local.example .env.local
#
# Then run:
#
#   make bootstrap
#
# This will distribute all secrets to the right places and configure
# the full local stack including OpenClaw + Telegram.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Provider (pick ONE, or add several)
# ---------------------------------------------------------------------------
# OpenRouter (recommended for local dev — single key, many models)
OPENROUTER_API_KEY=

# Direct providers for OpenCode / OmO model routing:
OPENAI_API_KEY=
GOOGLE_API_KEY=
MINIMAX_API_KEY=

# Anthropic usually works via OAuth/subscription in OpenCode.
# Add a direct API key only if you intentionally use Anthropic as a raw env provider.
# ANTHROPIC_API_KEY=

# OpenCode providers:
OPENCODE_API_KEY=

# ---------------------------------------------------------------------------
# LLM Model (optional — auto-detected from provider if empty)
# ---------------------------------------------------------------------------
# Override the default model. Examples:
#   OpenRouter: minimax/minimax-m2.5, anthropic/claude-sonnet-4-20250514
#   OpenAI:     openai/gpt-4o
#   Anthropic:  anthropic/claude-sonnet-4-20250514
# LLM_MODEL=minimax/minimax-m2.5

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
# Get from @BotFather in Telegram (/newbot command).
# Leave empty to skip Telegram channel setup.
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# OpenClaw Gateway Token (auto-generated if empty)
# ---------------------------------------------------------------------------
# OPENCLAW_GATEWAY_TOKEN=

# ---------------------------------------------------------------------------
# Cloudflare Tunnel — named tunnel token from Cloudflare dashboard
# ---------------------------------------------------------------------------
# CLOUDFLARE_TUNNEL_TOKEN=
