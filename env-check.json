{
  "$comment": "Auto-generated by `foundry init-env`. See: docs/pipeline/en/env-check.md",
  "compose_files": [
    "docker/compose.yaml",
    "docker/compose.core.yaml"
  ],
  "required_services": [
    {
      "name": "opensearch",
      "healthcheck": false
    },
    {
      "name": "postgres",
      "healthcheck": true
    },
    {
      "name": "rabbitmq",
      "healthcheck": true
    },
    {
      "name": "redis",
      "healthcheck": true
    }
  ],
  "optional_services": [
    "core",
    "core-scheduler",
    "core-e2e",
    "core-scheduler-e2e",
    "litellm",
    "opensearch-dashboards",
    "traefik"
  ],
  "healthcheck_urls": [
    {
      "url": "http://localhost:4000",
      "label": "LiteLLM proxy",
      "required": false
    },
    {
      "url": "http://localhost:9200",
      "label": "OpenSearch API",
      "required": false
    },
    {
      "url": "http://localhost:5601",
      "label": "OpenSearch Dashboards",
      "required": false
    },
    {
      "url": "http://localhost:15672",
      "label": "RabbitMQ management",
      "required": false
    },
    {
      "url": "http://localhost:8080",
      "label": "Traefik dashboard",
      "required": false
    },
    {
      "url": "http://localhost:18080",
      "label": "Core E2E app",
      "required": false
    }
  ],
  "commands": [
    {
      "cmd": "docker info",
      "label": "Docker daemon",
      "required": true
    },
    {
      "cmd": "git --version",
      "label": "Git",
      "required": true
    },
    {
      "cmd": "psql --version",
      "label": "PostgreSQL client (psql)",
      "required": false
    },
    {
      "cmd": "npx playwright --version",
      "label": "Playwright browsers",
      "required": false
    }
  ],
  "up_command": "docker compose -f docker/compose.yaml -f docker/compose.core.yaml up -d",
  "e2e_up_command": "docker compose -f docker/compose.yaml -f docker/compose.core.yaml --profile e2e up -d core-e2e"
}
