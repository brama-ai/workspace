#    - docker build -t brama/hello-agent:dev brama-agents/hello-agent/
# 4. Images transferred via: docker save IMAGE | ssh root@46.62.135.86 "k3s ctr images import -"
# 5. Namespace + secrets created:
#    - kubectl create namespace brama
#    - kubectl create secret generic brama-core-secrets ...
#    - kubectl create secret generic litellm-secrets ...
# 6. Helm install attempted: helm upgrade --install brama ... -f values-remote.yaml
#
# FAILURE REASONS:
